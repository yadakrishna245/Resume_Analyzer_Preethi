# ============================================================
# AI Resume Analyzer - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Frontend (Vite) - These are public and embedded in the build
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=your-cognito-client-id
VITE_API_ENDPOINT=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod
VITE_AWS_REGION=us-east-1

# Backend (Lambda) - These are set via SAM template parameters
# Do NOT commit actual keys! Use SAM parameter overrides or AWS Secrets Manager.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Override daily request limit (default: 3)
# DAILY_REQUEST_LIMIT=3
